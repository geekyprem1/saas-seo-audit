# Environment variables for SaaS SEO Audit.
# Copy this file to .env.local and fill in real values.

# Database (Neon Postgres recommended)
DATABASE_URL="postgresql://user:password@host:5432/saasseoaudit?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/saasseoaudit?sslmode=require"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# OpenRouter (primary: Gemini 2.5 Flash, fallback: DeepSeek V4 Flash)
OPENROUTER_API_KEY=
OPENROUTER_MODEL_PRIMARY=google/gemini-2.5-flash
OPENROUTER_MODEL_FALLBACK=deepseek/deepseek-chat

# Google PageSpeed Insights
GOOGLE_PSI_API_KEY=

# Upstash Redis (rate limiting + AI cache)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=info
CRON_SECRET=